# =============================================================
#  Profil dev — MODELE (template)
#  Copiez ce fichier en "application-dev.yml" et renseignez vos
#  valeurs locales. application-dev.yml est gitignore :
#  NE COMMITTEZ JAMAIS de secrets ici.
#  Les secrets sont resolus depuis des variables d'environnement
#  (ou un .env local) ; les ${VAR:defaut} fournissent un repli.
# =============================================================
spring:
  datasource:
    url: ${DB_URL:jdbc:mysql://localhost:3306/kafka_visualizer?createDatabaseIfNotExist=true&useSSL=false&serverTimezone=UTC&allowPublicKeyRetrieval=true}
    username: ${DB_USERNAME:root}
    password: ${DB_PASSWORD:}

  jpa:
    show-sql: false
    hibernate:
      ddl-auto: update
    properties:
      hibernate:
        format_sql: false
        show_sql: false

  kafka:
    bootstrap-servers: ${KAFKA_BOOTSTRAP_SERVERS:localhost:9092}

  mail:
    host: ${MAIL_HOST:smtp.gmail.com}
    port: ${MAIL_PORT:587}
    username: ${MAIL_USERNAME:}
    password: ${MAIL_PASSWORD:}
    properties:
      mail:
        smtp:
          auth: true
          starttls:
            enable: true
          connectiontimeout: 5000
          timeout: 5000
          writetimeout: 5000

cors:
  allowed-origins: ${CORS_ALLOWED_ORIGINS:http://localhost:3000,http://localhost:5173,chrome-extension://*}

app:
  # Genere un secret >=256 bits : openssl rand -base64 32
  jwt-secret: ${JWT_SECRET:}
  kafka:
    message-retention-hours: 24
    max-messages-per-topic: 10000

logging:
  level:
    root: INFO
    com.kafkaflow.visualizer: INFO
    com.zaxxer.hikari: WARN
    org.hibernate: WARN
