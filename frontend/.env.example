# =============================================================
#  Frontend (Vite) — MODELE
#  Copiez ce fichier en ".env" (gitignore) et ajustez si besoin.
#  En dev, le proxy Vite (vite.config.js) route /api et /ws vers
#  le backend ; ces variables ne sont utiles que pour pointer un
#  backend distant.
# =============================================================

# URL de base de l'API backend (laisser vide pour utiliser le proxy Vite)
VITE_API_URL=http://localhost:8080/api

# URL du WebSocket backend
VITE_WS_URL=http://localhost:8080/ws

# Environnement applicatif (development | production)
VITE_ENV=development
